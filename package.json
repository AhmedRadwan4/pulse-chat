{
  "name": "pulse-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev -p 8006",
    "build": "next build",
    "start": "cross-env NODE_ENV=production next start -p 8006",
    "db:init": "tsx --env-file=.env db/init.ts",
    "db:migrate": "tsx --env-file=.env db/migrate.ts",
    "seed": "tsx --env-file=.env db/indexer.ts && tsx --env-file=.env db/seeder.ts",
    "format": "biome format --write . && biome check --write --unsafe .",
    "server:dev": "cross-env NODE_ENV=development tsx watch --env-file=.env server/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "cross-env NODE_ENV=production node server/dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@base-ui/react": "^1.3.0",
    "@better-auth/kysely-adapter": "^1.5.6",
    "@pulse-chat/shared": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tabler/icons-react": "^3.41.0",
    "@tailwindcss/cli": "^4.2.2",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "axios": "^1.14.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "emoji-picker-react": "^4.18.0",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.14",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^14.4.1",
    "react-resizable-panels": "^4.7.6",
    "shadcn": "^4.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
